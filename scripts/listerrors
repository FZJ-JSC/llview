# Note: file $LLVIEW_HOME/scripts/listerrors must be sourced, e.g.:
# $ source $LLVIEW_HOME/scripts/listerrors

# If sourced, register auto-completion options and return
if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
    _myscript_completions() {
        local cur="${COMP_WORDS[COMP_CWORD]}"
        local options="delete"
        COMPREPLY=($(compgen -W "${options}" -- "${cur}"))
    }
    complete -F _myscript_completions $(basename ${BASH_SOURCE[0]})
    return
fi

cm="ls -ltr $LLVIEW_DATA/$LLVIEW_SYSTEMNAME/logs/*errlog $LLVIEW_DATA/$LLVIEW_SYSTEMNAME/logs/steps/*errlog | nl"
eval ${cm}

while [ $# -gt 0 ] ; do
	case $1 in
		delete) echo "Deleting error files..." ; cd $LLVIEW_DATA/$LLVIEW_SYSTEMNAME ; find ./ -name *errlog -delete ; exit 0 ;;
		open)
			if [ -z "$2" ]; then
				echo "Please provide a line number for the file to open."
				exit 1
			fi
			line_number=$2
			file=$(eval $cm | sed -n "${line_number}p" | awk '{print $NF}')
			if [ -f "$file" ]; then
				vim "$file"
			else
				echo "File $file not found."
				exit 1
			fi
			exit 0
			;;
	esac
	shift
done
